{
  "kind": "collectionType",
  "collectionName": "jbcommunications_blog_posts",
  "info": {
    "singularName": "jbcommunications-blog-post",
    "pluralName": "jbcommunications-blog-posts",
    "displayName": "Jbcommunications Blog Post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "excerpt": {
      "type": "blocks"
    },
    "content": {
      "type": "blocks"
    },
    "coverimage": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "publishedat": {
      "type": "datetime"
    },
    "writtenby": {
      "type": "string"
    },
    "subheader": {
      "type": "text"
    }
  }
}
